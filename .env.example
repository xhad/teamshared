# Copy to .env and fill in. The sptx server reads SPTX_* vars (or via SPTX_ENV_FILE).

# Server
SPTX_HOST=0.0.0.0
SPTX_PORT=8077
SPTX_LOG_LEVEL=info
# Set to true to disable bearer auth (local dev only). Default false.
SPTX_AUTH_DISABLED=false
# Path to the token registry. Tokens are issued via `sptx token mint <agent>`.
SPTX_TOKENS_FILE=./.sptx/tokens.json

# Postgres (pgvector)
SPTX_PG_HOST=localhost
SPTX_PG_PORT=5432
SPTX_PG_USER=sptx
SPTX_PG_PASSWORD=sptx
SPTX_PG_DB=sptx

# Redis (working memory)
SPTX_REDIS_URL=redis://localhost:6379/0
# Default TTL (seconds) for a working-memory session if the caller doesn't pass one.
SPTX_SESSION_TTL=86400

# Embeddings / LLM (Mem0 + distiller). Pick ONE provider per role.
# Option A: OpenAI
OPENAI_API_KEY=
SPTX_EMBED_PROVIDER=openai
SPTX_EMBED_MODEL=text-embedding-3-small
SPTX_EMBED_DIMS=1536
SPTX_LLM_PROVIDER=openai
SPTX_LLM_MODEL=gpt-4o-mini

# Option B: Local via Ollama (uncomment to use)
# SPTX_EMBED_PROVIDER=ollama
# SPTX_EMBED_MODEL=nomic-embed-text
# SPTX_EMBED_DIMS=768
# SPTX_LLM_PROVIDER=ollama
# SPTX_LLM_MODEL=qwen2.5:7b
# SPTX_OLLAMA_BASE_URL=http://localhost:11434

# Optional: Neo4j (off by default)
SPTX_NEO4J_ENABLED=false
SPTX_NEO4J_URL=bolt://localhost:7687
SPTX_NEO4J_USER=neo4j
SPTX_NEO4J_PASSWORD=neo4j

# Distillation worker
SPTX_DISTILL_ENABLED=true
SPTX_DISTILL_INTERVAL_SECONDS=30
