# Copy to .env and fill in. The teamshared server reads TEAMSHARED_* vars (or via TEAMSHARED_ENV_FILE).

# Server
TEAMSHARED_HOST=0.0.0.0
TEAMSHARED_PORT=8077
TEAMSHARED_LOG_LEVEL=info
# Set to true to disable bearer auth (local dev only). Default false.
TEAMSHARED_AUTH_DISABLED=false
# Path to the token registry. Tokens are issued via `teamshared token mint <agent>`,
# invite redemption, or POST /tokens/mint (admin secret).
TEAMSHARED_TOKENS_FILE=./.teamshared/tokens.json
# One-time invite codes for self-service token minting (default on).
TEAMSHARED_INVITES_FILE=./.teamshared/invites.json
TEAMSHARED_SELF_SERVICE_TOKENS=true
# Public HTTPS origin for invite links printed by `teamshared token invite-create`.
# TEAMSHARED_PUBLIC_URL=https://mcp.example.com
# Admin-only: create invites or mint tokens directly over HTTP.
# TEAMSHARED_MINT_SECRET=change-me-to-a-long-random-string

# Postgres (pgvector)
TEAMSHARED_PG_HOST=localhost
TEAMSHARED_PG_PORT=5432
TEAMSHARED_PG_USER=teamshared
TEAMSHARED_PG_PASSWORD=teamshared
TEAMSHARED_PG_DB=teamshared

# Redis (working memory)
TEAMSHARED_REDIS_URL=redis://localhost:6379/0
# Default TTL (seconds) for a working-memory session if the caller doesn't pass one.
TEAMSHARED_SESSION_TTL=86400

# Embeddings / LLM (Mem0 + distiller). Pick ONE provider per role.
# Option A: OpenAI
OPENAI_API_KEY=
TEAMSHARED_EMBED_PROVIDER=openai
TEAMSHARED_EMBED_MODEL=text-embedding-3-small
TEAMSHARED_EMBED_DIMS=1536
TEAMSHARED_LLM_PROVIDER=openai
TEAMSHARED_LLM_MODEL=gpt-4o-mini

# Option B: Local via Ollama (uncomment to use)
# TEAMSHARED_EMBED_PROVIDER=ollama
# TEAMSHARED_EMBED_MODEL=nomic-embed-text
# TEAMSHARED_EMBED_DIMS=768
# TEAMSHARED_LLM_PROVIDER=ollama
# TEAMSHARED_LLM_MODEL=qwen2.5:7b
# Bare-metal / pytest: http://localhost:11434
# Docker compose (server + distiller): http://host.docker.internal:11434
# TEAMSHARED_OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: Neo4j (off by default)
TEAMSHARED_NEO4J_ENABLED=false
TEAMSHARED_NEO4J_URL=bolt://localhost:7687
TEAMSHARED_NEO4J_USER=neo4j
TEAMSHARED_NEO4J_PASSWORD=neo4j

# Distillation worker
TEAMSHARED_DISTILL_ENABLED=true
TEAMSHARED_DISTILL_INTERVAL_SECONDS=30
