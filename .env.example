# Copy to .env and fill in. The actx server reads ACTX_* vars (or via ACTX_ENV_FILE).

# Server
ACTX_HOST=0.0.0.0
ACTX_PORT=8077
ACTX_LOG_LEVEL=info
# Set to true to disable bearer auth (local dev only). Default false.
ACTX_AUTH_DISABLED=false
# Path to the token registry. Tokens are issued via `actx token mint <agent>`.
ACTX_TOKENS_FILE=./.actx/tokens.json

# Postgres (pgvector)
ACTX_PG_HOST=localhost
ACTX_PG_PORT=5432
ACTX_PG_USER=actx
ACTX_PG_PASSWORD=actx
ACTX_PG_DB=actx

# Redis (working memory)
ACTX_REDIS_URL=redis://localhost:6379/0
# Default TTL (seconds) for a working-memory session if the caller doesn't pass one.
ACTX_SESSION_TTL=86400

# Embeddings / LLM (Mem0 + distiller). Pick ONE provider per role.
# Option A: OpenAI
OPENAI_API_KEY=
ACTX_EMBED_PROVIDER=openai
ACTX_EMBED_MODEL=text-embedding-3-small
ACTX_EMBED_DIMS=1536
ACTX_LLM_PROVIDER=openai
ACTX_LLM_MODEL=gpt-4o-mini

# Option B: Local via Ollama (uncomment to use)
# ACTX_EMBED_PROVIDER=ollama
# ACTX_EMBED_MODEL=nomic-embed-text
# ACTX_EMBED_DIMS=768
# ACTX_LLM_PROVIDER=ollama
# ACTX_LLM_MODEL=qwen2.5:7b
# Bare-metal / pytest: http://localhost:11434
# Docker compose (server + distiller): http://host.docker.internal:11434
# ACTX_OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: Neo4j (off by default)
ACTX_NEO4J_ENABLED=false
ACTX_NEO4J_URL=bolt://localhost:7687
ACTX_NEO4J_USER=neo4j
ACTX_NEO4J_PASSWORD=neo4j

# Distillation worker
ACTX_DISTILL_ENABLED=true
ACTX_DISTILL_INTERVAL_SECONDS=30
