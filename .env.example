# Copy to .env and fill in. The teamshared server reads TEAMSHARED_* vars (or via TEAMSHARED_ENV_FILE).

# Server
TEAMSHARED_HOST=0.0.0.0
TEAMSHARED_PORT=8077
TEAMSHARED_LOG_LEVEL=info
# development | production — production runs startup safety checks (RLS role, secrets, …).
# TEAMSHARED_DEPLOYMENT_ENV=development
# Public /memory dashboard: keep false in production (counts only; no memory snippets).
# TEAMSHARED_DASHBOARD_PUBLIC_CONTENT=false
# Edge rate limits (Redis). Disable only for local debugging.
# TEAMSHARED_RATE_LIMIT_ENABLED=true
# TEAMSHARED_RATE_LIMIT_MINT_PER_MINUTE=10
# TEAMSHARED_RATE_LIMIT_OTP_SEND_PER_MINUTE=3
# TEAMSHARED_RATE_LIMIT_OTP_VERIFY_PER_MINUTE=5
# TEAMSHARED_RATE_LIMIT_MCP_PER_MINUTE=120
# TEAMSHARED_RATE_LIMIT_V1_PER_MINUTE=120
# TEAMSHARED_IDEMPOTENCY_TTL_SECONDS=600
# TEAMSHARED_EXPORT_MAX_ITEMS=50000
# TEAMSHARED_RATE_LIMIT_ADMIN_EXPORT_PER_HOUR=6
# TEAMSHARED_RATE_LIMIT_ADMIN_PURGE_PER_HOUR=20
# Queue observability (Stage 4.3): /health + Prometheus gauges
# TEAMSHARED_QUEUE_DEPTH_WARN_THRESHOLD=100
# TEAMSHARED_QUEUE_DEPTH_CRITICAL_THRESHOLD=500
# TEAMSHARED_OBSERVABILITY_POLL_SECONDS=30
# Set to true to disable bearer auth (local dev only). Default false.
TEAMSHARED_AUTH_DISABLED=false
# One-time invite codes for self-service token minting (default on).
TEAMSHARED_INVITES_FILE=./.teamshared/invites.json
TEAMSHARED_SELF_SERVICE_TOKENS=true
# Public HTTPS origin for invite links printed by `teamshared token invite-create`.
# TEAMSHARED_PUBLIC_URL=https://teamshared.com
# Admin-only: create invites or mint tokens directly over HTTP.
# TEAMSHARED_MINT_SECRET=change-me-to-a-long-random-string

# /app console + multi-tenant /v1 API. Without a session secret the console
# login returns 503. Seed the owner with `teamshared provision-default-org`.
# TEAMSHARED_SESSION_SECRET=change-me-to-a-long-random-string
# TEAMSHARED_JOB_SIGNING_SECRET=change-me-to-a-long-random-string
# TEAMSHARED_DASHBOARD_OWNER_EMAIL=you@example.com
# TEAMSHARED_API_ADMIN_SECRET=change-me-to-a-long-random-string
# Console sign-in OTP: lifetime (seconds) and wrong-attempt cap before the code
# is invalidated. In AUTH_DISABLED dev mode the code is shown on the login page;
# otherwise it is emailed via SMTP (below). With neither, it can't be retrieved.
# TEAMSHARED_OTP_TTL_SECONDS=30
# TEAMSHARED_OTP_MAX_ATTEMPTS=5

# SMTP delivery for the sign-in OTP. Set host + from at minimum; username/password
# enable AUTH LOGIN, STARTTLS defaults on (typical for port 587).
TEAMSHARED_SMTP_HOST=smtp.resend.com
TEAMSHARED_SMTP_PORT=587
TEAMSHARED_SMTP_USERNAME=resend
TEAMSHARED_SMTP_PASSWORD=
TEAMSHARED_SMTP_FROM="teamshared <no-reply@loreum.org>"
TEAMSHARED_SMTP_STARTTLS=true

# Postgres (pgvector)
TEAMSHARED_PG_HOST=localhost
TEAMSHARED_PG_PORT=5432
TEAMSHARED_PG_USER=teamshared
TEAMSHARED_PG_PASSWORD=teamshared
TEAMSHARED_PG_DB=teamshared
# REQUIRED for tenant isolation. TEAMSHARED_PG_USER is the Postgres superuser,
# which BYPASSES row-level security -- if the app connects as it, every org can
# read every other org's data. Set a dedicated NOSUPERUSER/NOBYPASSRLS role
# here, then after `make migrate` run `teamshared provision-app-role` to create
# it and grant CRUD. Verify with `teamshared verify-rls`.
TEAMSHARED_PG_APP_USER=teamshared_app
TEAMSHARED_PG_APP_PASSWORD=change-me-to-a-long-random-string

# Redis (working memory)
TEAMSHARED_REDIS_URL=redis://localhost:6379/0
# Host port published for postgres/redis containers (change if 5432/6379 are taken)
# TEAMSHARED_PG_PORT=5433
# TEAMSHARED_REDIS_PORT=6380
# Default TTL (seconds) for a working-memory session if the caller doesn't pass one.
TEAMSHARED_SESSION_TTL=86400

# Embeddings / LLM (Mem0 + distiller). Pick ONE provider per role.
# Option A: OpenAI
OPENAI_API_KEY=
TEAMSHARED_EMBED_PROVIDER=openai
TEAMSHARED_EMBED_MODEL=text-embedding-3-small
TEAMSHARED_EMBED_DIMS=1536
TEAMSHARED_LLM_PROVIDER=openai
TEAMSHARED_LLM_MODEL=gpt-4o-mini

# Option B: Local via Ollama on the host (uncomment to use)
# TEAMSHARED_EMBED_PROVIDER=ollama
# TEAMSHARED_EMBED_MODEL=nomic-embed-text
# TEAMSHARED_EMBED_DIMS=768
# TEAMSHARED_LLM_PROVIDER=ollama
# TEAMSHARED_LLM_MODEL=qwen2.5:7b
# Bare-metal / pytest: http://localhost:11434
# Docker compose → host Ollama (default, GPU): http://host.docker.internal:11434
# TEAMSHARED_OLLAMA_BASE_URL=http://host.docker.internal:11434
# Start host Ollama: make ollama-host  (OLLAMA_HOST=0.0.0.0:11434)
# Bundled CPU ollama: http://ollama:11434 with COMPOSE_PROFILES=bundled-ollama
# Linux + host Ollama: allow docker bridge to 11434 if needed
# (e.g. `sudo ufw allow from 172.16.0.0/12 to any port 11434 proto tcp`).

# Neo4j relationship graph (always on). In docker compose the server reaches it
# at bolt://neo4j:7687 (the URL below is for bare-metal runs).
# Password must be >= 8 chars: Neo4j 5 rejects the factory default "neo4j".
TEAMSHARED_NEO4J_URL=bolt://localhost:7687
TEAMSHARED_NEO4J_USER=neo4j
TEAMSHARED_NEO4J_PASSWORD=change-me-min-8-chars

# Distillation worker
TEAMSHARED_DISTILL_ENABLED=true
TEAMSHARED_DISTILL_INTERVAL_SECONDS=30
